# =========================================================================
# ScriptFlow AI Environment Variables - Configuration Template
# =========================================================================

# GEMINI_API_KEY: Required for Gemini AI generation on the server.
# AI Studio automatically injects this at runtime from user secrets.
# For local development or deployment, paste your Google AI Studio key here.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted (Injected automatically at runtime on Cloud Run)
APP_URL="YOUR_APP_URL"

# =========================================================================
# Client-side Supabase Key Configurations (Vite/Next.js Compatible)
# =========================================================================

# VITE_ prefixed keys are exposed to the client in Vite (used in React and build containers)
VITE_SUPABASE_URL="YOUR_SUPABASE_PROJECT_URL"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_PUBLIC_KEY"

# Or standard NEXT_PUBLIC prefixed keys if exporting the codebase to Next.js
NEXT_PUBLIC_SUPABASE_URL="YOUR_SUPABASE_PROJECT_URL"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_PUBLIC_KEY"
